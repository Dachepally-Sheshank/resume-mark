{
  "manifest_version": 3,
  "name": "ResumeMark",
  "version": "0.3",
  "description": "Resume where you left off automatically.",
  "permissions": [
    "bookmarks",
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}